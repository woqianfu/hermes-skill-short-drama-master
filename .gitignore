# 短剧大师 .gitignore — 双仓推送脱敏规则

# 本地环境/配置
.env
.env.local
*.log
*.pid

# 操作系统
.DS_Store
Thumbs.db

# 会话/缓存
session-*
__pycache__/
*.pyc
node_modules/

# API Key 相关文件（即使注释了也排除）
**/api_keys*
**/credentials*

# 临时生成文件
tmp/
temp/
*.tmp

# 个人工作文件
personal-*
私人-*
我的-*

# 注意：assets/short-writing/ 包含完整剧本库，
# 如不想公开请取消下面注释
# assets/short-writing/
